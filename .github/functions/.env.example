# Cloudflare Pages Functions Environment Variables
# Copy this to Cloudflare Dashboard → Pages → Settings → Environment variables

# GitHub App webhook secret (must match GitHub App settings)
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# GitHub App token (installation token or PAT)
# Option 1: GitHub App installation token (recommended, expires after 1h)
# Option 2: Personal Access Token with repo + write:discussion scopes
GITHUB_APP_TOKEN=ghp_your_token_here

# Alternative token name (if using PAT)
GITHUB_TOKEN=ghp_your_token_here
