# ─────────────────────────────────────────────────────────────────────
# AladdinAI — Environment Configuration Template
# ─────────────────────────────────────────────────────────────────────
# QUICK START:
# 1. Copy this template to create your local environment file:
#    cp .env.example .env
# 2. Update the values in `.env` (especially production secrets).
# 3. The `.env` file is git-ignored to keep your credentials safe.
# ─────────────────────────────────────────────────────────────────────


# ── Database Configuration ───────────────────────────────────────────
# By default, the app uses local SQLite (backend/aladdinai.db).
# To use PostgreSQL via Docker:
# 1. Uncomment DATABASE_URL below.
# 2. Ensure POSTGRES_USER/PASSWORD match in the URL and variables.
# 3. Run: docker compose up postgres -d

POSTGRES_USER=aladdin_user
POSTGRES_PASSWORD=replace_with_secure_password
POSTGRES_DB=aladdinai

# Connection URL used by the backend application
# DATABASE_URL=postgresql+asyncpg://aladdin_user:replace_with_secure_password@postgres:5432/aladdinai


# ── Security & Authentication ────────────────────────────────────────
# JWT_SECRET: MUST be replaced in production!
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# FERNET_KEY: Used for encrypting sensitive data in the database.
# Generate via Python: from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())
FERNET_KEY=your-secret-fernet-key-here


# ── Networking ───────────────────────────────────────────────────────
# API URL for the Frontend (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000/api


# ── Optional Settings ────────────────────────────────────────────────
# Base URL for public webhooks (future use)
# PUBLIC_HOOK_BASE_URL=https://your-domain.com/api/wh
