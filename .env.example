# ─────────────────────────────────────────────────────────────────────
# AladdinAI — Environment Configuration Template
# ─────────────────────────────────────────────────────────────────────
# QUICK START:
# 1. Copy this template to create your local environment file:
#    cp .env.example .env
# 2. Update the values in `.env` (especially production secrets).
# 3. The `.env` file is git-ignored to keep your credentials safe.
# ─────────────────────────────────────────────────────────────────────


# ── Database Configuration ───────────────────────────────────────────
# By default, the app uses local SQLite (no setup required).
# For SQLite you can optionally set an absolute path to avoid CWD issues:
# DATABASE_URL=sqlite+aiosqlite:////absolute/path/to/backend/aladdinai.db
#
# To use PostgreSQL via Docker:
# 1. Uncomment DATABASE_URL (postgres) below.
# 2. Ensure POSTGRES_USER/PASSWORD match in the URL and variables.
# 3. Run: docker compose up postgres -d

POSTGRES_USER=aladdin_user
POSTGRES_PASSWORD=replace_with_secure_password
POSTGRES_DB=aladdinai

# Connection URL used by the backend application
# DATABASE_URL=postgresql+asyncpg://aladdin_user:replace_with_secure_password@postgres:5432/aladdinai


# ── Security & Authentication ────────────────────────────────────────
# ALADDIN_ENV: deployment mode. Leave unset for local dev (the backend
# infers dev from a SQLite DATABASE_URL). Set to "production" on any real
# deployment — the backend then REFUSES to boot if JWT_SECRET or
# TERMINAL_TOKEN_SECRET are left at their insecure placeholder values.
# ALADDIN_ENV=production

# JWT_SECRET: MUST be replaced in production!
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# FERNET_KEY: Used for encrypting sensitive data in the database.
# Generate via Python: from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())
FERNET_KEY=your-secret-fernet-key-here


# ── Networking ───────────────────────────────────────────────────────
# API URL for the Frontend (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000/api


# ── Terminal & Traefik Configuration ──────────────────────────────────
# User-facing host name fronted by Traefik (must match the rules)
TERMINAL_PUBLIC_HOST=localhost:8086
TERMINAL_PUBLIC_SCHEME=http
TERMINAL_TRAEFIK_ENTRYPOINT=web
TERMINAL_TRAEFIK_NETWORK=aladdin_terminal

# Secret keys for signing terminal session tokens (MUST be changed in prod)
TERMINAL_TOKEN_SECRET=change-me-terminal-token-secret
TERMINAL_TOKEN_TTL_SECONDS=3600
TERMINAL_SESSION_TTL_SECONDS=3600
TERMINAL_SESSION_COOKIE_NAME=aladdin_term_sess

# Traefik dynamic config directory mounted inside the backend container
TRAEFIK_DYNAMIC_CONFIG_DIR=/traefik-dynamic

# Remote Docker configuration (uncomment and configure for production remote daemon)
# DOCKER_REMOTE_URL=tcp://docker.example.com:2376
# DOCKER_TLS_CERT_PATH=/path/to/cert.pem
# DOCKER_TLS_KEY_PATH=/path/to/key.pem
# DOCKER_TLS_CA_PATH=/path/to/ca.pem
# DOCKER_TLS_VERIFY=true


# ── GitHub App Bots ──────────────────────────────────────────────────
# Webhook secret for verifying incoming GitHub webhooks
# Generate with: openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=

# AladdinAI[bot] - general purpose automation (issues, PRs, comments)
# Get these from: https://github.com/settings/apps/your-app-name
ALADDINAI_BOT_APP_ID=
ALADDINAI_BOT_INSTALLATION_ID=
# Private key in PEM format (replace newlines with \n in the string)
ALADDINAI_BOT_PRIVATE_KEY=

# NVIDIA Code Review[bot] - automated code reviews
NVIDIA_BOT_APP_ID=
NVIDIA_BOT_INSTALLATION_ID=
NVIDIA_BOT_PRIVATE_KEY=

# ── Telegram Notifications ───────────────────────────────────────
# Optional: for AladdinAI bot to send notifications about repo activity
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=


# ── Webhook Security ─────────────────────────────────────────────────
# Global webhook signing secret (used for verifying incoming webhooks).
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=change-me-webhook-secret

# WhatsApp / WAHA webhook HMAC secret (set same value in your WAHA config)
WHATSAPP_HOOK_HMAC=
# Update the channel ID (last path segment) to match your WAHA channel ID
WHATSAPP_WEBHOOK_URL=http://localhost:8000/api/webhooks/whatsapp_waha/1


# ── SSRF / URL Safety (dev only) ─────────────────────────────────────
# ALLOW_PRIVATE_URLS: set to true ONLY in local development when your
# self-hosted services (WAHA, etc.) run on a private network (e.g. OrbStack,
# Docker bridge 192.168.x.x, 10.x.x.x). NEVER enable in production.
# ALLOW_PRIVATE_URLS=true

# ALLOW_LOCALHOST_URLS: same as above but for loopback (127.x / ::1).
# ALLOW_LOCALHOST_URLS=true


# ── Optional Settings ────────────────────────────────────────────────
# Base URL for public webhooks (future use)
# PUBLIC_HOOK_BASE_URL=https://your-domain.com/api/wh


# ── Speech Services (NVIDIA Riva / Speech NIM) ───────────────────────
# Speech recognition/synthesis backend selection ("openai" or "riva_grpc")
SPEECH_BACKEND=riva_grpc

# Speech language (e.g. en-US, ru-RU)
SPEECH_LANGUAGE=en-US

# For OpenAI-compatible REST backend (e.g., self-hosted Speech NIM):
# SPEECH_BASE_URL=http://localhost:8000
# SPEECH_TTS_MODEL=chatterbox-multilingual-tts
# SPEECH_ASR_MODEL=parakeet-ctc-1.1b-asr

# NVIDIA Riva gRPC server URL (for riva_grpc backend)
RIVA_GRPC_URL=grpc.nvcf.nvidia.com:443

# NVIDIA Riva cloud function IDs (for NVCF hosted endpoints).
# Copy each Function ID from the model page on build.nvidia.com ("Try API" -> gRPC).
# Note: ASR and TTS are SEPARATE functions — use two different IDs.
# The deployed ASR model must match your call style: streaming models
# (e.g. nemotron-asr-streaming) require the streaming API, not offline.
RIVA_ASR_FUNCTION_ID=
RIVA_TTS_FUNCTION_ID=

# Riva TTS Voice name — must match the deployed TTS model's voice catalog.
# chatterbox-multilingual-tts: Chatterbox-Multilingual.<lang>.Male
#   e.g. Chatterbox-Multilingual.en-US.Male, Chatterbox-Multilingual.ru-RU.Male
# Keep RIVA_TTS_VOICE language in sync with SPEECH_LANGUAGE above.
RIVA_TTS_VOICE=Chatterbox-Multilingual.en-US.Male

# --- Web search (self-hosted SearXNG) ---
# The `web_search` agent tool queries this URL as {url}/search?q=...&format=json.
# docker-compose ships a `searxng` service reachable at this internal address,
# so agents get free web search with no paid API and no external gateway.
# Leave unset to fall back to DuckDuckGo HTML scraping (rate-limited/captcha-prone).
ALADDINAI_SEARCH_URL=http://searxng:8080

# Optional API key sent as X-API-KEY. Not needed for the in-stack SearXNG;
# only set it if you point ALADDINAI_SEARCH_URL at a gateway that requires auth.
# ALADDINAI_SEARCH_API_KEY=

# Secret key for the SearXNG service (any random string).
SEARXNG_SECRET=please-change-this-searxng-secret
