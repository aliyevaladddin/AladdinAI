# ─────────────────────────────────────────────────────────────────────
# AladdinAI — Environment Configuration Template
# ─────────────────────────────────────────────────────────────────────
# QUICK START:
# 1. Copy this template to create your local environment file:
#    cp .env.example .env
# 2. Update the values in `.env` (especially production secrets).
# 3. The `.env` file is git-ignored to keep your credentials safe.
# ─────────────────────────────────────────────────────────────────────


# ── Database Configuration ───────────────────────────────────────────
# By default, the app uses local SQLite (backend/aladdinai.db).
# To use PostgreSQL via Docker:
# 1. Uncomment DATABASE_URL below.
# 2. Ensure POSTGRES_USER/PASSWORD match in the URL and variables.
# 3. Run: docker compose up postgres -d

POSTGRES_USER=aladdin_user
POSTGRES_PASSWORD=replace_with_secure_password
POSTGRES_DB=aladdinai

# Connection URL used by the backend application
# DATABASE_URL=postgresql+asyncpg://aladdin_user:replace_with_secure_password@postgres:5432/aladdinai


# ── Security & Authentication ────────────────────────────────────────
# JWT_SECRET: MUST be replaced in production!
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# FERNET_KEY: Used for encrypting sensitive data in the database.
# Generate via Python: from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())
FERNET_KEY=your-secret-fernet-key-here


# ── Networking ───────────────────────────────────────────────────────
# API URL for the Frontend (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000/api


# ── Terminal & Traefik Configuration ──────────────────────────────────
# User-facing host name fronted by Traefik (must match the rules)
TERMINAL_PUBLIC_HOST=localhost:8086
TERMINAL_PUBLIC_SCHEME=http
TERMINAL_TRAEFIK_ENTRYPOINT=web
TERMINAL_TRAEFIK_NETWORK=aladdin_terminal

# Secret keys for signing terminal session tokens (MUST be changed in prod)
TERMINAL_TOKEN_SECRET=change-me-terminal-token-secret
TERMINAL_TOKEN_TTL_SECONDS=3600
TERMINAL_SESSION_TTL_SECONDS=3600
TERMINAL_SESSION_COOKIE_NAME=aladdin_term_sess

# Traefik dynamic config directory mounted inside the backend container
TRAEFIK_DYNAMIC_CONFIG_DIR=/traefik-dynamic

# Remote Docker configuration (uncomment and configure for production remote daemon)
# DOCKER_REMOTE_URL=tcp://docker.example.com:2376
# DOCKER_TLS_CERT_PATH=/path/to/cert.pem
# DOCKER_TLS_KEY_PATH=/path/to/key.pem
# DOCKER_TLS_CA_PATH=/path/to/ca.pem
# DOCKER_TLS_VERIFY=true


# ── GitHub App Bots ──────────────────────────────────────────────────
# Webhook secret for verifying incoming GitHub webhooks
# Generate with: openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=

# AladdinAI[bot] - general purpose automation (issues, PRs, comments)
# Get these from: https://github.com/settings/apps/your-app-name
ALADDINAI_BOT_APP_ID=
ALADDINAI_BOT_INSTALLATION_ID=
# Private key in PEM format (replace newlines with \n in the string)
ALADDINAI_BOT_PRIVATE_KEY=

# NVIDIA Code Review[bot] - automated code reviews
NVIDIA_BOT_APP_ID=
NVIDIA_BOT_INSTALLATION_ID=
NVIDIA_BOT_PRIVATE_KEY=

# ── Telegram Notifications ───────────────────────────────────────
# Optional: for AladdinAI bot to send notifications about repo activity
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=


# ── Optional Settings ────────────────────────────────────────────────
# Base URL for public webhooks (future use)
# PUBLIC_HOOK_BASE_URL=https://your-domain.com/api/wh

WHATSAPP_HOOK_HMAC=
WHATSAPP_WEBHOOK_URL=http://localhost:8000/api/webhooks/whatsapp_waha/4
