# ─────────────────────────────────────────────────────────────────────
# AladdinAI environment template — copy to `.env` and edit.
#
#   cp .env.example .env
#
# Only DATABASE_URL and JWT_SECRET *must* change in production.
# Everything else has working defaults for local development.
# ─────────────────────────────────────────────────────────────────────


# ── Database ─────────────────────────────────────────────────────────
# By default the backend uses local SQLite (backend/aladdinai.db) — no
# action needed. To use Postgres, uncomment DATABASE_URL below and run
# `docker compose up postgres -d`. POSTGRES_PASSWORD is consumed by the
# docker-compose service, not by the app directly.
POSTGRES_PASSWORD=aladdin_dev
# DATABASE_URL=postgresql+asyncpg://aladdin:aladdin_dev@postgres:5432/aladdinai


# ── JWT auth ─────────────────────────────────────────────────────────
# JWT_SECRET MUST be replaced in production — anyone who knows it can
# mint tokens for any user. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7


# ── Frontend → backend wiring ────────────────────────────────────────
# The Next.js app reads this at build time AND runtime to know where the
# FastAPI server lives. In docker-compose this becomes http://backend:8000/api.
NEXT_PUBLIC_API_URL=http://localhost:8000/api


# ── Optional: webhook trigger base URL (future) ──────────────────────
# When webhook-style triggers land we will return public URLs of the form
# `${PUBLIC_HOOK_BASE_URL}/{token}`. Leave blank during local dev — the
# UI will fall back to NEXT_PUBLIC_API_URL.
# PUBLIC_HOOK_BASE_URL=https://aliyev.site/AladdinAI/wh
