{
  "name": "frontend",
  "version": "2.2.1",
  "description": "Sovereign AI Interface for AladdinAI",
  "author": "Aladdin Aliyev",
  "repository": {
    "type": "git",
    "url": "https://github.com/aliyevaladddin/AladdinAI.git"
  },
  "private": true,
  "main": "main.cjs",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "rcf:check": "rcf-cli audit .",
    "electron:dev": "concurrently \"next dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "next build && electron-builder"
  },
  "build": {
    "appId": "com.aladdin.ai",
    "productName": "AladdinAI",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "main.cjs",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-serve": "^3.0.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^1.25.0",
    "next": "16.2.10",
    "rcf-protocol": "^2.1.8",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "recharts": "^3.9.2",
    "shadcn": "^4.13.1",
    "sonner": "^2.0.7",
    "sql-formatter": "^15.8.2",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "xlsx": "npm:@sheetjs/xlsx@0.20.2",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "@swc/jest": "^0.2.39",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^26",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^10.0.3",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "eslint": "^10",
    "eslint-config-next": "16.2.10",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "tailwindcss": "^4",
    "typescript": "^6",
    "wait-on": "^9.0.10"
  },
  "overrides": {
    "minimatch@10": {
      "brace-expansion": "^5.0.6"
    },
    "qs": "^6.15.2",
    "postcss": "^8.5.10",
    "js-yaml": "^4.2.0",
    "@babel/core": "^7.29.7",
    "dompurify": "^3.4.11"
  },
  "optionalDependencies": {
    "lightningcss-linux-arm64-gnu": "^1.32.0"
  }
}
