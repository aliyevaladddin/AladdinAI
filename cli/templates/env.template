# AladdinAI environment configuration.
# The `npx aladdin-ai init` wizard fills in secure random values for the
# secret-looking variables below. Edit as needed.

# ── Database ─────────────────────────────────────────────────────────
POSTGRES_USER=aladdin_user
POSTGRES_PASSWORD=__GENERATED__
POSTGRES_DB=aladdinai

# ── Security (regenerate before exposing to the internet) ────────────
# JWT_SECRET: openssl rand -hex 32
JWT_SECRET=__GENERATED__
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# FERNET_KEY: 32 random bytes base64-urlsafe encoded
FERNET_KEY=__GENERATED__

# ── Networking ───────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# ── Image version (advanced) ─────────────────────────────────────────
# Pin to a specific release if "latest" causes you issues.
# ALADDINAI_VERSION=1.0.0
# ── Web Search ─────────────────────────────────────────
# AladdinAI has a built-in meta-search engine (DuckDuckGo + Wikipedia).
# Web search works out of the box.
#
# Optional: Brave Search API for richer results (2 000 req/month free).
# Register at https://api.search.brave.com/register
# BRAVE_API_KEY=
